class Solution {
    public long[] distance(int[] nums) {
        long arr[] = new long[nums.length];
        HashMap<Integer, Integer> freq = new HashMap<>();
        HashMap<Integer, Long> sum = new HashMap<>();

        for(int i=0; i<nums.length; i++){
            
            arr[i] = (long) i*freq.getOrDefault(nums[i],0) - sum.getOrDefault(nums[i],0L);
            freq.put(nums[i], freq.getOrDefault(nums[i],0)+1);
            sum.put(nums[i], sum.getOrDefault(nums[i],0L)+i);
        }

        freq.clear();
        sum.clear();

        for(int i=nums.length-1; i>=0; i--){
            
            arr[i] = arr[i] - (long)i*freq.getOrDefault(nums[i],0) + sum.getOrDefault(nums[i],0l);
            freq.put(nums[i], freq.getOrDefault(nums[i],0)+1);
            sum.put(nums[i], sum.getOrDefault(nums[i],0L)+i);
        }

        return arr;
    }
}
